# ===== 한국투자증권 API 설정 =====
# https://apiportal.koreainvestment.com 에서 발급

# 앱 키 / 앱 시크릿
KIS_APP_KEY=
KIS_APP_SECRET=

# 계좌번호 (8자리-2자리, 예: 50012345-01)
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01

# 모의투자 여부 (true=모의투자, false=실전투자)
KIS_IS_PAPER=true

# ===== 삼성전자 매매 설정 =====

# 종목코드 (삼성전자: 005930, 삼성전자우: 005935)
STOCK_CODE=005930
STOCK_NAME=삼성전자

# 매매 전략 (rsi, macd, bollinger, ma_cross, combined)
STRATEGY=combined

# 1회 최대 매수 금액 (원)
MAX_BUY_AMOUNT=1000000

# 최대 보유 수량 (주)
MAX_HOLD_QTY=100

# 손절 비율 (%)
STOP_LOSS_PCT=3.0

# 익절 비율 (%)
TAKE_PROFIT_PCT=5.0

# 매매 체크 주기 (초)
POLL_INTERVAL_SEC=60

# 매매 허용 시간 (HH:MM, 한국 주식시장 09:00~15:20)
TRADING_START_TIME=09:05
TRADING_END_TIME=15:15

# ===== 텔레그램 알림 =====
# @BotFather에서 봇 생성 후 토큰 입력
TELEGRAM_TOKEN=
# 봇에게 메시지 보낸 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 chat_id 확인
TELEGRAM_CHAT_ID=

# ===== 로깅 =====
LOG_LEVEL=INFO
