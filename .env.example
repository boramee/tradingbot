# 업비트 API 키 설정
# https://upbit.com/mypage/open_api_management 에서 발급
UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# 매매 설정
TICKER=KRW-BTC
INVESTMENT_RATIO=0.1
MAX_INVESTMENT_KRW=100000

# 전략 설정 (rsi, macd, bollinger, combined)
STRATEGY=combined

# 리스크 관리
STOP_LOSS_PCT=3.0
TAKE_PROFIT_PCT=5.0
MAX_DAILY_TRADES=10

# 로깅 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
