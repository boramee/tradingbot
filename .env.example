# 복사 후 .env 로 저장하고 값을 채우세요. .env 는 절대 커밋하지 마세요.

# ccxt 거래소 ID (예: binance, upbit, bybit, okx)
EXCHANGE_ID=binance

API_KEY=
API_SECRET=
# OKX 등 일부 거래소만 필요
# API_PASSPHRASE=

# true: 주문 API는 호출하지 않고 로그만 남김 (기본 권장)
DRY_RUN=true

# 실주문을 허용하려면 DRY_RUN=false 이고 아래 문구를 정확히 입력
# TRADING_LIVE_CONFIRM=I_UNDERSTAND

# --- 거래소 간 스프레드 / 김프 스캔 (spread, kimchi 명령) ---
# ARB_SYMBOLS=BTC/USDT,ETH/USDT
# ARB_EXCHANGES=binance,okx,bybit,kraken,upbit,bithumb
# watch 시 임계값(%%). 미설정이면 매 틱 전체 출력
# ARB_MIN_SPREAD_PCT=0.15
# kimchi 명령에서 해외 기준 거래소
# ARB_GLOBAL_EXCHANGE=binance

# USDT 법정화폐 괴리 스캔 (premium 명령, 거래소 간 차익과는 별개)
# PREMIUM_EXCHANGES=upbit,bithumb,binance,okx
