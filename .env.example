# ===== 거래소 API 키 설정 =====

# 업비트 (https://upbit.com/mypage/open_api_management)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# 빗썸 (https://www.bithumb.com/api_support/management_api)
BITHUMB_ACCESS_KEY=
BITHUMB_SECRET_KEY=

# 바이낸스 (https://www.binance.com/en/my/settings/api-management)
BINANCE_ACCESS_KEY=
BINANCE_SECRET_KEY=

# 바이비트 (https://www.bybit.com/app/user/api-management)
BYBIT_ACCESS_KEY=
BYBIT_SECRET_KEY=

# ===== 재정거래 설정 =====

# 모니터링 대상 코인 (쉼표 구분)
TARGET_SYMBOLS=BTC,ETH,XRP,SOL,DOGE

# 최소 수익률 (%) - 이 이상 차이가 나야 거래 실행
MIN_PROFIT_PCT=0.5

# 슬리피지 허용 범위 (%)
MAX_SLIPPAGE_PCT=0.3

# 1회 최대 거래 금액 (USDT 기준)
MAX_TRADE_USDT=1000

# 가격 조회 주기 (초)
POLL_INTERVAL_SEC=2

# ===== 김치프리미엄 설정 =====
# 김치프리미엄 매수 기준 (%) - 이 이하일 때 한국에서 매수 고려
KIMCHI_BUY_THRESHOLD=1.0
# 김치프리미엄 매도 기준 (%) - 이 이상일 때 한국에서 매도 고려
KIMCHI_SELL_THRESHOLD=3.0

# ===== 로깅 =====
LOG_LEVEL=INFO
